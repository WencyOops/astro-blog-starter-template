---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="zh">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="seed-body">
		<!-- Scanline overlay -->
		<div class="scanlines" aria-hidden="true"></div>

		<!-- Particle canvas background -->
		<canvas id="seed-canvas" aria-hidden="true"></canvas>

		<!-- HUD corner decorations -->
		<div class="hud-corner hud-tl" aria-hidden="true"></div>
		<div class="hud-corner hud-tr" aria-hidden="true"></div>
		<div class="hud-corner hud-bl" aria-hidden="true"></div>
		<div class="hud-corner hud-br" aria-hidden="true"></div>

		<!-- Cursor glow -->
		<div class="cursor-glow" id="cursorGlow" aria-hidden="true"></div>

		<Header />

		<main class="seed-main">
			<!-- Hero section -->
			<section class="hero-section">
				<div class="hex-grid" aria-hidden="true">
					<div class="hex hex-1"></div>
					<div class="hex hex-2"></div>
					<div class="hex hex-3"></div>
					<div class="hex hex-4"></div>
					<div class="hex hex-5"></div>
				</div>

				<div class="hero-content">
					<div class="status-bar" aria-hidden="true">
						<span class="status-dot"></span>
						<span class="status-text">SYSTEM ONLINE — ZAFT NETWORK LINK ESTABLISHED</span>
					</div>

					<div class="title-wrapper">
						<div class="title-label">MOBILE SUIT BLOG SYSTEM</div>
						<h1 class="hero-title">
							<span class="title-line-1">FREEDOM</span>
							<span class="title-line-2">BLOG</span>
						</h1>
						<div class="title-sub">— PHASE-SHIFT ARMOR ACTIVE —</div>
					</div>

					<div class="seed-description">
						<div class="desc-panel">
							<div class="panel-header">
								<span class="panel-icon">◈</span>
								<span>PILOT DATA</span>
							</div>
							<p>
								欢迎进入ZAFT战略信息网络。本系统搭载最新的
								<a href="https://astro.build/" class="seed-link">ASTRO驱动框架</a>
								，配备Phase-Shift装甲级别的内容防护。
							</p>
							<p>
								操作员可通过下方导航模块访问博客档案库，
								或自定义本MS（Multi-purpose Station）的战术配置。
							</p>
						</div>
					</div>

					<div class="mission-list">
						<div class="mission-header">
							<span class="mission-icon">▸</span> 任务清单
						</div>
						<ul class="seed-list">
							<li><span class="li-marker">◆</span> 编辑 <a href="/src/pages/index.astro" class="seed-link">src/pages/index.astro</a> 自定义本页</li>
							<li><span class="li-marker">◆</span> 在 <a href="/src/components/Header.astro" class="seed-link">Header.astro</a> 配置导航链接</li>
							<li><span class="li-marker">◆</span> 更新 <a href="/src/components/Footer.astro" class="seed-link">Footer.astro</a> 中的驾驶员信息</li>
							<li><span class="li-marker">◆</span> 查阅 <a href="/blog" class="seed-link">博客档案</a> 中的战报记录</li>
							<li><span class="li-marker">◆</span> 在 <a href="/src/layouts/BlogPost.astro" class="seed-link">BlogPost.astro</a> 调整战报模板</li>
						</ul>
					</div>

					<div class="cta-row">
						<a href="/blog" class="seed-btn primary">
							<span class="btn-bg"></span>
							<span class="btn-text">进入档案库</span>
							<span class="btn-arrow">→</span>
						</a>
						<a href="https://docs.astro.build/" class="seed-btn secondary" target="_blank">
							<span class="btn-bg"></span>
							<span class="btn-text">操作手册</span>
							<span class="btn-arrow">↗</span>
						</a>
					</div>
				</div>

				<!-- Side HUD panel -->
				<aside class="side-hud" aria-label="系统状态">
					<div class="hud-panel">
						<div class="hud-title">SYSTEM STATUS</div>
						<div class="hud-stat">
							<span class="stat-label">PHASE-SHIFT</span>
							<div class="stat-bar"><div class="stat-fill" style="width:92%"></div></div>
							<span class="stat-val">92%</span>
						</div>
						<div class="hud-stat">
							<span class="stat-label">SEED FACTOR</span>
							<div class="stat-bar"><div class="stat-fill seed-fill" style="width:78%"></div></div>
							<span class="stat-val">78%</span>
						</div>
						<div class="hud-stat">
							<span class="stat-label">POWER</span>
							<div class="stat-bar"><div class="stat-fill power-fill" style="width:100%"></div></div>
							<span class="stat-val">∞</span>
						</div>
						<div class="hud-divider"></div>
						<div class="hud-coord">
							<div class="coord-label">COORDINATES</div>
							<div class="coord-val" id="coordDisplay">L4 — PLANT</div>
						</div>
						<div class="hud-emblem" aria-hidden="true">
							<svg viewBox="0 0 80 80" width="60" height="60">
								<!-- ZAFT-style emblem: stylized wing/crest -->
								<polygon points="40,5 55,20 70,15 60,35 75,45 55,45 50,65 40,55 30,65 25,45 5,45 20,35 10,15 25,20" fill="none" stroke="#e63030" stroke-width="2" opacity="0.8"/>
								<circle cx="40" cy="40" r="10" fill="none" stroke="#e63030" stroke-width="1.5" opacity="0.6"/>
								<circle cx="40" cy="40" r="4" fill="#e63030" opacity="0.9"/>
							</svg>
						</div>
					</div>
				</aside>
			</section>
		</main>

		<Footer />

		<script>
			// ── Canvas particle field ──────────────────────────────────────────────
			(function () {
				const canvas = document.getElementById('seed-canvas') as HTMLCanvasElement;
				if (!canvas) return;
				const ctx = canvas.getContext('2d')!;

				function resize() {
					canvas.width = window.innerWidth;
					canvas.height = window.innerHeight;
				}
				resize();
				window.addEventListener('resize', resize);

				interface Star {
					x: number; y: number;
					r: number; alpha: number;
					vx: number; vy: number;
					pulse: number; pulseSpeed: number;
				}

				const stars: Star[] = Array.from({ length: 180 }, () => ({
					x: Math.random() * window.innerWidth,
					y: Math.random() * window.innerHeight,
					r: Math.random() * 1.5 + 0.3,
					alpha: Math.random() * 0.7 + 0.2,
					vx: (Math.random() - 0.5) * 0.15,
					vy: (Math.random() - 0.5) * 0.15,
					pulse: Math.random() * Math.PI * 2,
					pulseSpeed: Math.random() * 0.02 + 0.005,
				}));

				// Hex grid lines (decorative)
				const hexLines: { x1: number; y1: number; x2: number; y2: number; alpha: number }[] = [];
				for (let i = 0; i < 12; i++) {
					hexLines.push({
						x1: Math.random() * window.innerWidth,
						y1: Math.random() * window.innerHeight,
						x2: Math.random() * window.innerWidth,
						y2: Math.random() * window.innerHeight,
						alpha: Math.random() * 0.07 + 0.02,
					});
				}

				function draw() {
					ctx.clearRect(0, 0, canvas.width, canvas.height);

					// Draw faint hex lines
					hexLines.forEach(l => {
						ctx.beginPath();
						ctx.moveTo(l.x1, l.y1);
						ctx.lineTo(l.x2, l.y2);
						ctx.strokeStyle = `rgba(100,180,255,${l.alpha})`;
						ctx.lineWidth = 0.5;
						ctx.stroke();
					});

					// Draw stars with pulse
					stars.forEach(s => {
						s.pulse += s.pulseSpeed;
						const a = s.alpha * (0.6 + 0.4 * Math.sin(s.pulse));
						ctx.beginPath();
						ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
						ctx.fillStyle = `rgba(200,230,255,${a})`;
						ctx.fill();

						s.x += s.vx;
						s.y += s.vy;
						if (s.x < 0) s.x = canvas.width;
						if (s.x > canvas.width) s.x = 0;
						if (s.y < 0) s.y = canvas.height;
						if (s.y > canvas.height) s.y = 0;
					});

					requestAnimationFrame(draw);
				}
				draw();
			})();

			// ── Cursor glow ────────────────────────────────────────────────────────
			(function () {
				const glow = document.getElementById('cursorGlow');
				if (!glow) return;
				let mx = -200, my = -200;
				document.addEventListener('mousemove', e => {
					mx = e.clientX; my = e.clientY;
				});
				function update() {
					glow!.style.transform = `translate(${mx - 150}px, ${my - 150}px)`;
					requestAnimationFrame(update);
				}
				update();
			})();

			// ── Coordinate ticker ──────────────────────────────────────────────────
			(function () {
				const el = document.getElementById('coordDisplay');
				if (!el) return;
				const coords = ['L4 — PLANT', 'L5 — HELIOPOLIS', 'EARTH ORBIT', 'JACHIN DUE', 'MENDEL COLONY'];
				let i = 0;
				setInterval(() => {
					el.classList.add('coord-flash');
					setTimeout(() => {
						i = (i + 1) % coords.length;
						el.textContent = coords[i];
						el.classList.remove('coord-flash');
					}, 300);
				}, 3000);
			})();
		</script>
	</body>
</html>

<style>
/* ── SEED 全局变量 ─────────────────────────────────────────── */
:root {
	--seed-bg: #03050f;
	--seed-red: #e63030;
	--seed-red-dim: rgba(230,48,48,0.18);
	--seed-blue: #1a8fff;
	--seed-blue-dim: rgba(26,143,255,0.15);
	--seed-gold: #f5c842;
	--seed-white: #ddeeff;
	--seed-panel: rgba(5,15,40,0.85);
	--seed-border: rgba(26,143,255,0.35);
	--seed-glow: 0 0 12px rgba(26,143,255,0.6), 0 0 30px rgba(26,143,255,0.2);
	--seed-glow-red: 0 0 12px rgba(230,48,48,0.7), 0 0 30px rgba(230,48,48,0.25);
	--font-mono: 'Courier New', 'Consolas', monospace;
}

/* ── 全页面底色 ───────────────────────────────────────────── */
.seed-body {
	background: var(--seed-bg) !important;
	color: var(--seed-white);
	font-family: var(--font-mono);
	min-height: 100vh;
	overflow-x: hidden;
}

/* Canvas 背景 */
#seed-canvas {
	position: fixed;
	inset: 0;
	z-index: 0;
	pointer-events: none;
}

/* 扫描线 */
.scanlines {
	position: fixed;
	inset: 0;
	z-index: 1;
	pointer-events: none;
	background: repeating-linear-gradient(
		0deg,
		transparent,
		transparent 2px,
		rgba(0,0,0,0.08) 2px,
		rgba(0,0,0,0.08) 4px
	);
	animation: scanMove 8s linear infinite;
}
@keyframes scanMove {
	from { background-position: 0 0; }
	to   { background-position: 0 40px; }
}

/* 鼠标光晕 */
.cursor-glow {
	position: fixed;
	width: 300px;
	height: 300px;
	border-radius: 50%;
	background: radial-gradient(circle, rgba(26,143,255,0.12) 0%, transparent 70%);
	pointer-events: none;
	z-index: 2;
	transition: none;
}

/* ── HUD 四角装饰 ─────────────────────────────────────────── */
.hud-corner {
	position: fixed;
	width: 60px;
	height: 60px;
	z-index: 10;
	pointer-events: none;
	opacity: 0;
	animation: cornerIn 0.8s ease forwards;
}
.hud-tl { top: 12px; left: 12px; border-top: 2px solid var(--seed-blue); border-left: 2px solid var(--seed-blue); animation-delay: 0.2s; }
.hud-tr { top: 12px; right: 12px; border-top: 2px solid var(--seed-red); border-right: 2px solid var(--seed-red); animation-delay: 0.3s; }
.hud-bl { bottom: 12px; left: 12px; border-bottom: 2px solid var(--seed-blue); border-left: 2px solid var(--seed-blue); animation-delay: 0.4s; }
.hud-br { bottom: 12px; right: 12px; border-bottom: 2px solid var(--seed-red); border-right: 2px solid var(--seed-red); animation-delay: 0.5s; }
@keyframes cornerIn {
	from { opacity: 0; transform: scale(0.5); }
	to   { opacity: 1; transform: scale(1); }
}

/* ── Header 覆盖 ──────────────────────────────────────────── */
.seed-body :global(header) {
	background: rgba(3,8,24,0.92) !important;
	border-bottom: 1px solid var(--seed-border);
	backdrop-filter: blur(8px);
	position: relative;
	z-index: 20;
	box-shadow: 0 2px 20px rgba(26,143,255,0.15);
}
.seed-body :global(header a) {
	color: var(--seed-white) !important;
	font-family: var(--font-mono);
	letter-spacing: 0.08em;
	text-transform: uppercase;
	font-size: 0.78em;
}
.seed-body :global(nav a.active),
.seed-body :global(nav a:hover) {
	color: var(--seed-blue) !important;
	border-bottom-color: var(--seed-blue) !important;
	text-shadow: 0 0 8px var(--seed-blue);
}

/* ── Footer 覆盖 ──────────────────────────────────────────── */
.seed-body :global(footer) {
	background: rgba(3,8,24,0.92) !important;
	border-top: 1px solid var(--seed-border);
	color: rgba(170,200,255,0.5);
	font-family: var(--font-mono);
	font-size: 0.75em;
	letter-spacing: 0.06em;
	position: relative;
	z-index: 20;
}

/* ── Main ─────────────────────────────────────────────────── */
.seed-main {
	position: relative;
	z-index: 5;
	width: 100%;
	max-width: 100%;
	padding: 0;
	margin: 0;
	min-height: calc(100vh - 80px);
}

/* ── Hero Section ─────────────────────────────────────────── */
.hero-section {
	display: grid;
	grid-template-columns: 1fr 280px;
	gap: 2rem;
	max-width: 1200px;
	margin: 0 auto;
	padding: 3rem 2rem 4rem;
	align-items: start;
}
@media (max-width: 900px) {
	.hero-section { grid-template-columns: 1fr; padding: 2rem 1rem; }
	.side-hud { order: -1; }
}

/* ── 浮动六边形背景 ───────────────────────────────────────── */
.hex-grid {
	position: absolute;
	inset: 0;
	overflow: hidden;
	pointer-events: none;
	z-index: 0;
}
.hex {
	position: absolute;
	clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
	border: 1px solid rgba(26,143,255,0.12);
	background: rgba(26,143,255,0.03);
	animation: hexFloat 12s ease-in-out infinite;
}
.hex-1 { width:160px;height:185px; top:5%; left:5%;  animation-delay:0s;   animation-duration:14s; }
.hex-2 { width:100px;height:115px; top:60%;left:2%;  animation-delay:2s;   animation-duration:11s; }
.hex-3 { width:200px;height:231px; top:10%;right:5%; animation-delay:1s;   animation-duration:16s; opacity:0.5; }
.hex-4 { width:80px; height:92px;  top:75%;right:8%; animation-delay:3s;   animation-duration:10s; }
.hex-5 { width:130px;height:150px; top:40%;left:45%; animation-delay:1.5s; animation-duration:13s; opacity:0.4; }
@keyframes hexFloat {
	0%,100% { transform: translateY(0)   rotate(0deg);   opacity:0.6; }
	33%      { transform: translateY(-18px) rotate(3deg); opacity:1;   }
	66%      { transform: translateY(10px)  rotate(-2deg);opacity:0.4; }
}

/* ── Hero 内容 ────────────────────────────────────────────── */
.hero-content {
	position: relative;
	z-index: 2;
	display: flex;
	flex-direction: column;
	gap: 2rem;
	opacity: 0;
	animation: slideInLeft 0.9s ease 0.4s forwards;
}
@keyframes slideInLeft {
	from { opacity:0; transform: translateX(-40px); }
	to   { opacity:1; transform: translateX(0); }
}

/* 状态条 */
.status-bar {
	display: flex;
	align-items: center;
	gap: 0.6rem;
	font-size: 0.7em;
	letter-spacing: 0.12em;
	color: var(--seed-blue);
	text-transform: uppercase;
}
.status-dot {
	width: 8px; height: 8px;
	border-radius: 50%;
	background: var(--seed-blue);
	box-shadow: var(--seed-glow);
	animation: blink 1.4s ease-in-out infinite;
}
@keyframes blink {
	0%,100% { opacity:1; }
	50%      { opacity:0.2; }
}

/* 标题区 */
.title-wrapper { display:flex; flex-direction:column; gap:0.4rem; }
.title-label {
	font-size: 0.68em;
	letter-spacing: 0.25em;
	color: rgba(170,200,255,0.55);
	text-transform: uppercase;
}
.hero-title {
	display: flex;
	flex-direction: column;
	line-height: 1;
	margin: 0;
}
.title-line-1 {
	font-size: clamp(3rem, 8vw, 6.5rem);
	font-weight: 900;
	letter-spacing: 0.15em;
	color: transparent;
	-webkit-text-stroke: 2px var(--seed-blue);
	text-shadow: none;
	animation: titleGlow 3s ease-in-out infinite alternate;
}
.title-line-2 {
	font-size: clamp(2rem, 5vw, 4rem);
	font-weight: 700;
	letter-spacing: 0.3em;
	color: var(--seed-red);
	text-shadow: var(--seed-glow-red);
	animation: titleGlowRed 2.5s ease-in-out infinite alternate;
}
@keyframes titleGlow {
	from { -webkit-text-stroke-color: var(--seed-blue); filter: drop-shadow(0 0 8px rgba(26,143,255,0.6)); }
	to   { -webkit-text-stroke-color: #7dd3fc;          filter: drop-shadow(0 0 20px rgba(26,143,255,0.9)); }
}
@keyframes titleGlowRed {
	from { text-shadow: var(--seed-glow-red); }
	to   { text-shadow: 0 0 20px rgba(230,48,48,0.9), 0 0 50px rgba(230,48,48,0.4); }
}
.title-sub {
	font-size: 0.72em;
	letter-spacing: 0.2em;
	color: var(--seed-gold);
	opacity: 0.8;
	text-transform: uppercase;
	margin-top: 0.3rem;
}

/* ── 描述面板 ─────────────────────────────────────────────── */
.desc-panel {
	background: var(--seed-panel);
	border: 1px solid var(--seed-border);
	border-left: 3px solid var(--seed-blue);
	padding: 1.2rem 1.5rem;
	backdrop-filter: blur(6px);
	position: relative;
	clip-path: polygon(0 0, calc(100% - 16px) 0, 100% 16px, 100% 100%, 0 100%);
}
.desc-panel::before {
	content:'';
	position:absolute;
	top:0; right:0;
	width:16px; height:16px;
	border-bottom: 1px solid var(--seed-border);
	border-left: 1px solid var(--seed-border);
}
.panel-header {
	display:flex; align-items:center; gap:0.5rem;
	font-size:0.7em; letter-spacing:0.15em;
	color: var(--seed-blue); text-transform:uppercase;
	margin-bottom: 0.8rem;
}
.panel-icon { font-size:1.1em; }
.desc-panel p {
	font-size: 0.85em;
	line-height: 1.8;
	color: rgba(200,225,255,0.8);
	margin-bottom: 0.6rem;
	font-family: inherit;
}

/* ── 任务列表 ─────────────────────────────────────────────── */
.mission-list {
	background: var(--seed-panel);
	border: 1px solid var(--seed-border);
	border-left: 3px solid var(--seed-red);
	padding: 1.2rem 1.5rem;
	clip-path: polygon(0 0, 100% 0, 100% calc(100% - 16px), calc(100% - 16px) 100%, 0 100%);
	position: relative;
}
.mission-list::after {
	content:'';
	position:absolute;
	bottom:0; right:0;
	width:16px; height:16px;
	border-top: 1px solid var(--seed-border);
	border-left: 1px solid var(--seed-border);
}
.mission-header {
	font-size:0.7em; letter-spacing:0.15em;
	color: var(--seed-red); text-transform:uppercase;
	margin-bottom:0.8rem;
}
.seed-list {
	list-style: none;
	padding: 0; margin: 0;
	display:flex; flex-direction:column; gap:0.5rem;
}
.seed-list li {
	display:flex; align-items:center; gap:0.6rem;
	font-size:0.82em;
	color: rgba(200,225,255,0.75);
	padding: 0.35rem 0;
	border-bottom: 1px solid rgba(26,143,255,0.08);
	transition: color 0.25s, padding-left 0.25s;
}
.seed-list li:hover {
	color: var(--seed-white);
	padding-left: 0.4rem;
}
.li-marker {
	color: var(--seed-red);
	font-size: 0.7em;
	flex-shrink: 0;
}

/* ── 链接 ─────────────────────────────────────────────────── */
.seed-link {
	color: var(--seed-blue);
	text-decoration: none;
	border-bottom: 1px solid rgba(26,143,255,0.35);
	transition: color 0.2s, border-color 0.2s, text-shadow 0.2s;
}
.seed-link:hover {
	color: #7dd3fc;
	border-color: #7dd3fc;
	text-shadow: 0 0 8px rgba(26,143,255,0.7);
}

/* ── 按钮 ─────────────────────────────────────────────────── */
.cta-row { display:flex; gap:1rem; flex-wrap:wrap; }
.seed-btn {
	position: relative;
	display: inline-flex;
	align-items: center;
	gap: 0.5rem;
	padding: 0.7rem 1.8rem;
	font-family: var(--font-mono);
	font-size: 0.82em;
	letter-spacing: 0.15em;
	text-transform: uppercase;
	text-decoration: none;
	overflow: hidden;
	cursor: pointer;
	transition: transform 0.2s;
	clip-path: polygon(8px 0%, 100% 0%, calc(100% - 8px) 100%, 0% 100%);
}
.seed-btn:hover { transform: translateY(-2px); }
.seed-btn.primary {
	color: var(--seed-bg);
	background: var(--seed-blue);
	box-shadow: var(--seed-glow);
}
.seed-btn.primary:hover { background: #7dd3fc; }
.seed-btn.secondary {
